# ============================================================
# LinuxOps Enterprise Server
# File: configs/firewall/firewall.rules
# Description: UFW Firewall Configuration Reference
# ============================================================

# ------------------------------------------------------------
# Reset Existing Rules
# ------------------------------------------------------------
ufw --force reset

# ------------------------------------------------------------
# Default Policies
# ------------------------------------------------------------
ufw default deny incoming
ufw default allow outgoing

# ------------------------------------------------------------
# Allow SSH
# ------------------------------------------------------------
ufw allow 22/tcp comment 'SSH'

# ------------------------------------------------------------
# Allow HTTP
# ------------------------------------------------------------
ufw allow 80/tcp comment 'HTTP'

# ------------------------------------------------------------
# Allow HTTPS
# ------------------------------------------------------------
ufw allow 443/tcp comment 'HTTPS'

# ------------------------------------------------------------
# Allow Samba
# ------------------------------------------------------------
ufw allow 137/udp comment 'Samba NetBIOS'
ufw allow 138/udp comment 'Samba Datagram'
ufw allow 139/tcp comment 'Samba Session'
ufw allow 445/tcp comment 'Samba SMB'

# ------------------------------------------------------------
# Allow ICMP (Ping)
# ------------------------------------------------------------
# Note:
# UFW allows outbound ping by default.
# For inbound ICMP configuration, use before.rules if required.

# ------------------------------------------------------------
# Allow Local Network (Modify if Needed)
# ------------------------------------------------------------
ufw allow from 192.168.1.0/24 comment 'Local Network'

# ------------------------------------------------------------
# Block Telnet
# ------------------------------------------------------------
ufw deny 23/tcp comment 'Block Telnet'

# ------------------------------------------------------------
# Block FTP (Optional)
# Uncomment if FTP server is not used.
# ------------------------------------------------------------
# ufw deny 20/tcp
# ufw deny 21/tcp

# ------------------------------------------------------------
# Block SMTP (Optional)
# ------------------------------------------------------------
# ufw deny 25/tcp

# ------------------------------------------------------------
# Rate Limit SSH (Protection Against Brute Force)
# ------------------------------------------------------------
ufw limit 22/tcp comment 'Limit SSH'

# ------------------------------------------------------------
# Enable Logging
# ------------------------------------------------------------
ufw logging on

# ------------------------------------------------------------
# Enable Firewall
# ------------------------------------------------------------
ufw --force enable

# ------------------------------------------------------------
# Display Status
# ------------------------------------------------------------
ufw status verbose